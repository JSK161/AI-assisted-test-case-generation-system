<view class="page">
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px;">
    <text class="nav-back" bindtap="goBack">←</text>
    <text class="nav-title">对话历史</text>
    <view class="nav-right"></view>
  </view>

  <view class="list-scroll" style="padding-bottom:{{safeAreaBottom + 12}}px;">
    <view wx:if="{{loading}}" class="loading-state">
      <view wx:for="{{3}}" wx:key="*this" class="skeleton" />
    </view>

    <view wx:elif="{{list.length === 0}}" class="empty-state">
      <text style="font-size:40px;margin-bottom:12px;">💬</text>
      <text>暂无对话历史</text>
      <button class="btn-primary" style="margin-top:16px;width:auto;padding:0 24px;" bindtap="goChat">开始新对话</button>
    </view>

    <view wx:else class="conv-list">
      <view wx:for="{{list}}" wx:key="id" class="conv-item" bindtap="openConv" data-id="{{item.id}}">
        <view class="conv-icon">💬</view>
        <view class="conv-content">
          <text class="conv-title">{{item.title}}</text>
          <text class="conv-time">{{item.updatedAt}}</text>
        </view>
        <text class="conv-del" catchtap="deleteConv" data-id="{{item.id}}" data-title="{{item.title}}">✕</text>
      </view>
    </view>
  </view>
</view>
