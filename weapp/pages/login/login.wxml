<view class="auth-page" style="padding-top:{{statusBarHeight + 20}}px;">
  <view class="auth-card">
    <view class="auth-header">
      <view class="brand-icon">
        <text>✦</text>
      </view>
      <text class="auth-title">登录</text>
      <text class="auth-subtitle">AI 辅助测试用例生成系统</text>
    </view>

    <view class="auth-form">
      <view class="form-group">
        <input class="form-input" placeholder="用户名" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="form-group">
        <input class="form-input" password placeholder="密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <button class="btn-primary" loading="{{loading}}" disabled="{{!username || !password}}" bindtap="handleLogin">登 录</button>
    </view>

    <view class="auth-footer">
      <text>还没有账号？</text>
      <navigator url="/pages/register/register" class="auth-link">立即注册</navigator>
    </view>

    <view class="auth-demo">
      <text>演示账号：admin / 123456</text>
    </view>
  </view>
</view>
