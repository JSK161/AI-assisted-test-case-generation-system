<view class="page" style="overflow-x:hidden;width:100%;">
  <view class="nav-bar" style="padding-top:{{statusBarHeight + 14}}px;">
    <view class="nav-left"></view>
    <text class="nav-title">个人中心</text>
    <view class="nav-right"></view>
  </view>

  <view class="profile-scroll" style="padding-bottom:{{safeAreaBottom + 12}}px;">
    <!-- Profile Header -->
    <view class="profile-card">
      <view class="profile-avatar">{{userAvatar}}</view>
      <view class="profile-info">
        <text class="profile-name">{{displayName}}</text>
        <text class="profile-username">@{{displayUsername}}</text>
        <view class="profile-tags">
          <text class="tag {{displayRoleTag}}">{{displayRoleText}}</text>
          <text wx:if="{{hasEmail}}" class="tag tag-email">{{displayEmail}}</text>
          <text wx:else class="tag tag-email">未设置邮箱</text>
        </view>
      </view>
    </view>

    <!-- Settings -->
    <view class="settings-grid">
      <view class="setting-card" bindtap="editApiKey">
        <text class="setting-icon">🔑</text>
        <text class="setting-label">API Key</text>
        <text class="setting-value">{{maskedApiKey || '未设置'}}</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-card" bindtap="editEmail">
        <text class="setting-icon">📧</text>
        <text class="setting-label">邮箱</text>
        <text class="setting-value">{{displayEmail}}</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-card" bindtap="editPassword">
        <text class="setting-icon">🔒</text>
        <text class="setting-label">密码</text>
        <text class="setting-value">••••••••</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <!-- Admin: User Management -->
    <view wx:if="{{isAdmin}}" class="admin-section">
      <text class="section-title">👑 用户管理（{{userList.length}}人）</text>
      <view class="user-table">
        <view class="user-row header">
          <text class="uc-id">ID</text>
          <text class="uc-name">用户名</text>
          <text class="uc-email">邮箱</text>
          <text class="uc-role">角色</text>
        </view>
        <view wx:for="{{userList}}" wx:key="id" class="user-row">
          <text class="uc-id">{{item.id}}</text>
          <text class="uc-name">{{item.username}}</text>
          <text class="uc-email">{{item.email || '-'}}</text>
          <view class="uc-role">
            <picker mode="selector" range="{{roleOptions}}" value="{{item.role === 'ADMIN' ? 0 : 1}}" bindchange="onRoleChange" data-id="{{item.id}}">
              <text class="tag {{item.role === 'ADMIN' ? 'tag-admin' : 'tag-member'}}">{{item.role}}</text>
            </picker>
          </view>
        </view>
      </view>
    </view>

    <!-- Logout -->
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
