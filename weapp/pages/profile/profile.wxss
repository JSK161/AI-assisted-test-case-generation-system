.page { min-height: 100vh; background: var(--color-bg); }
.profile-scroll { height: calc(100vh - 100px); padding: 12px 16px 30px; }

.profile-card { display:flex; align-items:center; gap:16px; padding:20px; background:var(--color-surface); border-radius:12px; border:1px solid var(--color-border); box-shadow:var(--shadow-light); margin-bottom:14px; }
.profile-avatar { width:56px; height:56px; line-height:56px; text-align:center; border-radius:50%; background:linear-gradient(135deg,#6c63ff,#a855f7); color:#fff; font-size:22px; font-weight:600; box-shadow:0 4px 12px rgba(108,99,255,0.3); }
.profile-info { flex:1; }
.profile-name { display:block; font-size:18px; font-weight:600; color:var(--color-heading); }
.profile-username { display:block; font-size:13px; color:var(--color-muted); margin-top:2px; }
.profile-tags { display:flex; gap:6px; margin-top:6px; }
.tag { padding:0 8px; font-size:11px; font-weight:600; border-radius:4px; line-height:22px; }
.tag-admin { background:#fff3e6; color:#e68a2e; }
.tag-member { background:var(--color-primary-soft); color:var(--color-primary); }
.tag-email { background:var(--color-surface-soft); color:var(--color-muted); }

.settings-grid { display:grid; gap:10px; margin-bottom:14px; }
.setting-card { display:flex; align-items:center; gap:12px; padding:14px 16px; background:var(--color-surface); border:1px solid var(--color-border); border-radius:10px; box-shadow:var(--shadow-light); }
.setting-icon { font-size:20px; }
.setting-label { flex:1; font-size:14px; font-weight:500; color:var(--color-text); }
.setting-value { font-size:13px; color:var(--color-muted); }
.setting-arrow { font-size:18px; color:var(--color-muted); }

.admin-section { margin-bottom:20px; }
.section-title { display:block; font-size:15px; font-weight:600; color:var(--color-heading); margin-bottom:10px; }
.user-table { background:var(--color-surface); border:1px solid var(--color-border); border-radius:10px; overflow:hidden; }
.user-row { display:grid; grid-template-columns:44px 1fr 1.2fr 60px; align-items:center; padding:10px 14px; font-size:13px; border-bottom:1px solid var(--color-border); }
.user-row:last-child { border-bottom:none; }
.user-row.header { font-weight:600; color:var(--color-muted); background:var(--color-surface-soft); font-size:12px; }
.uc-id { color:var(--color-muted); }
.uc-name { color:var(--color-text); }
.uc-email { color:var(--color-muted); }
.uc-role { text-align:center; }

.logout-btn { width:100%; height:44px; line-height:44px; text-align:center; color:#f56c6c; background:var(--color-surface); border:1px solid var(--color-border); border-radius:10px; font-size:15px; margin-top:10px; }
